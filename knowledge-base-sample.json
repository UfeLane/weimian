  "knowledgeEntries": [
    {
      "id": "sleep-what-is-insomnia",
      "category": "sleep",
      "question": "什么是失眠？",
      "answer": "失眠是一种常见睡眠障碍，即使有合适的睡眠时间和环境，仍可能出现入睡困难、睡眠维持困难或睡眠质量不佳。",
      "keywords": ["失眠", "定义", "睡不着"],
      "sourceId": "nhlbi-insomnia"
    },
    {
      "id": "sleep-healthy-habits",
      "category": "sleep",
      "question": "想改善睡眠，睡前习惯可以先改什么？",
      "answer": "可先从规律作息、卧室保持安静偏暗偏凉、睡前少看电子屏幕、避免临睡前摄入咖啡因和酒精、减少午后小睡等习惯开始。",
      "keywords": ["睡前", "习惯", "作息", "咖啡因", "酒精"],
      "sourceId": "nhlbi-insomnia-treatment"
    },
    {
      "id": "med-dayvigo-indication",
      "category": "medication",
      "question": "达卫可是治疗什么的？",
      "answer": "根据 FDA 标签，DAYVIGO（lemborexant）用于治疗成人失眠，尤其是入睡困难和/或睡眠维持困难。",
      "keywords": ["达卫可", "DAYVIGO", "适应症"],
      "sourceId": "fda-dayvigo-label"
    },
    {
      "id": "med-dayvigo-how-to-take",
      "category": "medication",
      "question": "达卫可应该在什么时间吃？",
      "answer": "FDA 标签建议在睡前立即服用，并确保离计划醒来时间至少还有 7 小时；与餐同服或餐后很快服用可能延迟起效。",
      "keywords": ["什么时候吃", "睡前", "7小时", "餐后"],
      "sourceId": "fda-dayvigo-label"
    },
    {
      "id": "profile-followup-date",
      "category": "profile",
      "question": "我的下一次复诊时间和关注点是什么？",
      "answer": "根据当前档案，下一次复诊计划为 2026.07.03，建议带上睡眠日记，并反馈入睡耗时、白天嗜睡、漏服情况和药物耐受性。",
      "keywords": ["下一次复诊", "复诊时间", "关注点"],
      "sourceId": "internal-profile"
    },
    {
      "id": "followup-prepare-visit",
      "category": "followup",
      "question": "复诊前应该准备什么？",
      "answer": "可准备近 1 至 2 周的睡眠记录、当前用药清单、出现过的不适和最想确认的 3 个问题。",
      "keywords": ["复诊", "准备", "看医生", "带什么"],
      "sourceId": "nhlbi-insomnia"
    },
    {
      "id": "followup-contact-doctor",
      "category": "followup",
      "question": "复诊之间如果出现新情况，需要做什么？",
      "answer": "如果出现新的症状、原有症状加重，或者药物副作用变得明显，应及时联系医生，而不是等到下一次门诊时再统一处理。",
      "keywords": ["新情况", "症状加重", "副作用", "联系医生"],
      "sourceId": "nhlbi-insomnia-living"
    }
